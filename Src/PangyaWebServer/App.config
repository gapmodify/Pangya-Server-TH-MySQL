<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- Root directory for web files -->
    <add key="WebRoot" value="www" />
    
    <!-- Server port (Default: 8080) -->
    <add key="Port" value="8080" />
  </appSettings>
</configuration>
